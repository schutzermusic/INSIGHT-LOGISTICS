## ═══════════════════════════════════════════════════════
## INSIGHT LOGISTICS — Environment Variables
## ═══════════════════════════════════════════════════════

## ── Feature Flags ─────────────────────────────────────
## Multimodal Mobilization Intelligence (new flow). Keep false until the
## new engine reaches parity; the current Route Intelligence screen is
## unaffected while this is off.
VITE_FEATURE_MOBILIZATION=false

## ── Supabase ──────────────────────────────────────────
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

## ── Frontend (public, exposed via Vite) ──────────────
## Used for: Maps JavaScript API, Places Autocomplete
## Restrict this key to: Maps JS API + Places API only
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_frontend_key_here

## ── Backend (private, server-only) ───────────────────
## Used for: Routes API, Geocoding API, Toll lookup
## Restrict this key to: Directions API + Geocoding API + Routes API
GOOGLE_SERVER_API_KEY=your_google_server_key_here

## ── SerpAPI (Google Flights) ─────────────────────────
## Get your key at: https://serpapi.com/
## VITE_SERPAPI_KEY: legacy client-side path (current Route Intelligence screen).
## SERPAPI_KEY: server-side key used by the new mobilization flow (§26) — the
## browser no longer needs the key. Prefer SERPAPI_KEY going forward.
VITE_SERPAPI_KEY=your_serpapi_key_here
SERPAPI_KEY=your_serpapi_key_here

## ── ClickBus Partner API (bus tickets, server-only) ──
## Preferred bus source. Docs: https://developer.clickbus.com.br/reference/autenticação
## Auth: HTTP Basic (username:password) → JWT. Requires an onboarded partner account.
CLICKBUS_USER=your_clickbus_username_here
CLICKBUS_PASS=your_clickbus_password_here
## Environment: "production" or "staging"
CLICKBUS_ENV=staging

## ── Quero Passagem API (bus tickets, server-only) ────
## API docs: https://queropassagem.com.br/api/doc
## Authentication: HTTP Basic Auth
QUERO_PASSAGEM_USER=your_api_username_here
QUERO_PASSAGEM_PASS=your_api_password_here
QUERO_PASSAGEM_AFFILIATE_CODE=your_affiliate_code_here
## Environment: "sandbox" or "production"
QUERO_PASSAGEM_ENV=sandbox
